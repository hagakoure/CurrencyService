{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "currency-service",
    "Audience": "currency-client",
    "SecretKey": "super-secret-key-for-jwt-must-be-32-chars-long!!"
  },
  "ReverseProxy": {
    "Routes": {
      "user-auth-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}",
          "Methods": [ "POST" ]
        },
        "AuthorizationPolicy": "anonymous"
      },
      "user-protected-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "finance-route": {
        "ClusterId": "finance-cluster",
        "Match": {
          "Path": "/api/finance/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "user-cluster": {
        "Destinations": {
          "user1": {
            "Address": "http://currency-user-service:8080",
            "Health": {
              "Active": "http://currency-user-service:8080/health",
              "Interval": "00:00:10",
              "Timeout": "00:00:05",
              "Policy": "ConsecutiveFailures"
            }
          }
        }
      },
      "finance-cluster": {
        "Destinations": {
          "finance1": {
            "Address": "http://currency-finance-service:8080",
            "Health": {
              "Active": "http://currency-finance-service:8080/health",
              "Interval": "00:00:10",
              "Timeout": "00:00:05",
              "Policy": "ConsecutiveFailures"
            }
          }
        }
      }
    }
  }
}